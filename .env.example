# === General ===
LOG_LEVEL=INFO
REPORTS_DIR=./reports

# === Redash (replaces direct Redshift) ===
# Queries created via API from https://github.com/visable-dev/analytics_dashboard_queries
REDASH_URL=https://redash.visable.com
REDASH_API_KEY=***
REDASH_UV_QUERY_ID=1291   # [SEO Agent] Daily UV by Domain Channel Device
REDASH_AB_QUERY_ID=1292   # [SEO Agent] Daily AB by Domain Channel Device

# === Google Search Console ===
# Path to a service-account JSON file with GSC access, or OAuth client creds
GSC_SERVICE_ACCOUNT_JSON=/path/to/gsc-sa.json
# Comma-separated list of verified sites (one per domain)
GSC_SITES=https://www.europages.fr/,https://www.europages.de/,https://www.europages.com.tr/,https://www.europages.ro/,https://www.europages.pl/

# === Jira / Confluence (release correlation) ===
JIRA_BASE_URL=https://visable.atlassian.net
JIRA_EMAIL=seo-agent@visable.com
JIRA_API_TOKEN=change_me
JIRA_PROJECT_KEYS=EP,UG
CONFLUENCE_BASE_URL=https://visable.atlassian.net/wiki
CONFLUENCE_SPACE=UG

# === Server logs ===
# Directory or S3 URI to server access logs
SERVER_LOG_PATH=s3://visable-logs/ep/access/

# === SSR check ===
SSR_USER_AGENT=Mozilla/5.0 (compatible; Googlebot/2.1; +http://www.google.com/bot.html)
SSR_RENDER_TIMEOUT=30

# === External factors ===
SEMRUSH_API_KEY=change_me
DATAFORSEO_LOGIN=change_me
DATAFORSEO_PASSWORD=change_me
GOOGLE_SEARCH_STATUS_URL=https://status.search.google.com/incidents.json
